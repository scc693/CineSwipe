{
  "name": "cineswipe",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:rules:unit": "vitest run --config vitest.rules.config.ts",
    "test:rules": "firebase emulators:exec --project demo-cineswipe --only firestore \"npm run test:rules:unit\"",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "firebase": "^11.8.0",
    "firebase-admin": "^13.0.2",
    "next": "^15.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.25.7"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^4.0.1",
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.2.0",
    "firebase-tools": "^14.0.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
